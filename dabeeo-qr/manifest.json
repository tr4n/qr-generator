{
  "manifest_version": 3,
  "name": "Dabeeo QR",
  "version": "1.0.2",
  "description": "Generate QR code for the current web page.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "ic_dabeeo.png",
      "48": "ic_dabeeo.png",
      "128": "ic_dabeeo.png"
    }
  },
  "icons": {
    "16": "ic_dabeeo.png",
    "48": "ic_dabeeo.png",
    "128": "ic_dabeeo.png"
  },
  "permissions": [
    "activeTab",
    "clipboardWrite"
  ]
}
